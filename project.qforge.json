      "logic_trees": [
        {
          "id": "logic_0003",
          "name": "update_script_3_imported",
          "output_file": "src/scenes/main_scene.rs",
          "nodes": [
            {
              "Action": {
                "Expr": {
                  "raw": "if ! game_over { let spawn_timer = canvas . get_f32 (\"spawn_timer\") + DT ; if spawn_timer >= SPAWN_INTERVAL { canvas . set_var (\"spawn_timer\" , 0.0f32) ; spawn_asteroid (canvas) ; } else { canvas . set_var (\"spawn_timer\" , spawn_timer) ; } }"
                }
              }
            },
            {
              "Action": {
                "Expr": {
                  "raw": "if ! game_over { let thrusting = canvas . is_key_held (& Key :: Character ('w' . to_string ())) || canvas . is_key_held (& Key :: Named (NamedKey :: ArrowUp)) ; if thrusting { let angle = canvas . get_f32 (\"player_angle\") . to_radians () ; let mx = angle . sin () * PLAYER_THRUST ; let my = - angle . cos () * PLAYER_THRUST ; canvas . run (Action :: ApplyMomentum { target : Target :: name (\"player\") , value : (mx , my) , }) ; } }"
                }
              }
            },
            {
              "Action": {
                "Expr": {
                  "raw": "canvas . set_var (\"bullet_cooldown\" , cooldown)"
                }
              }
            },
            {
              "Action": {
                "Expr": {
                  "raw": "if ! game_over && cooldown <= 0.0 && canvas . is_key_held (& Key :: Named (NamedKey :: Space)) { canvas . set_var (\"bullet_cooldown\" , 0.17f32) ; fire_bullet (canvas) ; }"
                }
              }
            },
            {
              "Action": {
                "Expr": {
                  "raw": "if ! game_over { wrap_player (canvas) ; resolve_bullet_asteroid_hits (canvas) ; cleanup_offscreen_projectiles (canvas) ; }"
                }
              }
            },
            {
              "Action": {
                "Expr": {
                  "raw": "refresh_hud (canvas)"
                }
              }
            }
          ],
          "referenced_object_ids": []
        }
      ],
